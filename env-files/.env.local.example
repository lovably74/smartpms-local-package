# ═══════════════════════════════════════════════════════════
# SmartPMS 로컬 개발 환경 변수 설정 파일
# 이 파일을 복사하여 smartpms/.env 로 저장하세요.
# ═══════════════════════════════════════════════════════════

# ───────────────────────────────────────────
# [필수] 데이터베이스 연결
# 우선순위: DATABASE_URL > DB_HOST/DB_PORT/DB_USER/DB_PASSWORD/DB_NAME
# 원격 MariaDB(10.10.10.30) 사용 기본값
# ───────────────────────────────────────────
DATABASE_URL=
DB_HOST=10.10.10.30
DB_PORT=3306
DB_USER=smartcon
DB_PASSWORD=
DB_NAME=smartpms

# ───────────────────────────────────────────
# [필수] JWT 세션 시크릿 (임의 문자열로 변경 권장)
# ───────────────────────────────────────────
JWT_SECRET=local-dev-jwt-secret-please-change-this

# ───────────────────────────────────────────
# [로컬 우회] Manus OAuth 설정
# 로컬에서는 OAuth 로그인이 작동하지 않으므로
# 아래 설정으로 로컬 개발 모드를 활성화합니다.
# ───────────────────────────────────────────
VITE_APP_ID=local
OAUTH_SERVER_URL=http://localhost:3000
VITE_OAUTH_PORTAL_URL=http://localhost:3000
OWNER_OPEN_ID=local-owner-001
OWNER_NAME=로컬관리자

# ───────────────────────────────────────────
# [선택] Manus 플랫폼 전용 API (로컬에서는 빈 값)
# 파일 업로드(S3), AI, 알림 기능은 로컬에서 비활성화됩니다.
# ───────────────────────────────────────────
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# ───────────────────────────────────────────
# [선택] 앱 표시 정보
# ───────────────────────────────────────────
VITE_APP_TITLE=SmartPMS - WBS 수행관리
VITE_APP_LOGO=
