# UTF-8 (no BOM). 서버에서 /opt/smartpms/.env.deploy 로 저장.
# 비밀값(DB, JWT 등)은 /opt/smartpms/.env 에만 둔다.

# 백엔드: 루프백만 (외부 브라우저는 Nginx 포트를 사용)
HOST=127.0.0.1
PORT=8090
TRUST_PROXY=1

# 공개 URL
# [개발] HTTP 5080 사용
# [운영] SSL 인증서 적용 후 https://wbs.smartpms.net:5443 으로 변경
OAUTH_SERVER_URL=http://wbs.smartpms.net:5080
VITE_OAUTH_PORTAL_URL=http://wbs.smartpms.net:5080
