# UTF-8 (no BOM). 서버에서 /opt/smartpms/.env.deploy 로 저장.
# 비밀값(DB, JWT 등)은 /opt/smartpms/.env 에만 둔다.

# 백엔드: 루프백만 (외부 브라우저는 Nginx wbs.smartpms.net:5443 만 사용)
HOST=127.0.0.1
PORT=8090
TRUST_PROXY=1

# 공개 URL (Nginx 사설 TLS 종료 기준)
OAUTH_SERVER_URL=https://wbs.smartpms.net:5443
VITE_OAUTH_PORTAL_URL=https://wbs.smartpms.net:5443
